{
  "version": 1,
  "projects": {
    "angular-ssr": {
      "projectType": "application",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputMode": "server",
            "outputPath": "dist/angular-ssr",
            "server": "src/main.server.ts",
            "ssr": true
          }
        }
      }
    }
  }
}
